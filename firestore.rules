rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'items', 'totalAmount', 'platform', 'status', 'createdAt']) &&
             data.keys().size() <= 11 &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.customerPhone is string && data.customerPhone.size() <= 50 &&
             data.items is list && data.items.size() <= 50 &&
             data.items.size() >= 1 &&
             data.totalAmount is number &&
             data.platform is string && data.platform in ['WhatsApp', 'iFood', '99Food'] &&
             data.status is string && data.status in ['pending', 'preparing', 'dispatched', 'completed', 'cancelled'] &&
             data.createdAt is number &&
             (!('customerAddress' in data) || (data.customerAddress is string && data.customerAddress.size() <= 200)) &&
             (!('paymentMethod' in data) || (data.paymentMethod is string && data.paymentMethod.size() <= 50)) &&
             (!('addressReference' in data) || (data.addressReference is string && data.addressReference.size() <= 200)) &&
             (!('orderNotes' in data) || (data.orderNotes is string && data.orderNotes.size() <= 500));
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) &&
                       isValidOrder(incoming()) &&
                       incoming().status == 'pending';
      allow read, list: if isSignedIn();
      allow update: if isSignedIn() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
